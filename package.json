{
  "name": "ecovision-security-sentinel",
  "version": "1.0.0",
  "description": "Advanced Real-Time Security Monitoring & Threat Detection System",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "desktop": "electron .",
    "preapp:build": "powershell -Command \"taskkill /F /IM EcoVisionSentinel.exe /IM electron.exe 2>$null; exit 0\"",
    "app:build": "next build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "lucide-react": "^1.12.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "keywords": [
    "security",
    "surveillance",
    "monitoring",
    "detection",
    "threat",
    "dashboard",
    "esp32",
    "yolo",
    "ai",
    "real-time"
  ],
  "author": "EcoVision Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.ecovision.sentinel",
    "productName": "EcoVisionSentinel",
    "asarUnpack": [
      "node_modules/next/**/*",
      ".next/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "EcoVisionSentinel-Setup-${version}.exe"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "next.config.*",
      "package.json"
    ],
    "extraResources": [
      { "from": "app/backend.py", "to": "backend/backend.py" },
      { "from": "app/schema_final.sql", "to": "backend/schema_final.sql" },
      { "from": "maincode/main.py", "to": "maincode/main.py" },
      { "from": "maincode/robbery_vandalism.py", "to": "maincode/robbery_vandalism.py" },
      { "from": "maincode/x3d_violence_detector.py", "to": "maincode/x3d_violence_detector.py" },
      { "from": "maincode/pose_landmarker_heavy.task", "to": "maincode/pose_landmarker_heavy.task" },
      { "from": "weights", "to": "weights" },
      { "from": "config.json", "to": "config.json" },
      { "from": "requirements.txt", "to": "requirements.txt" }
    ]
  }
}